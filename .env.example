# --- API (Supabase Postgres — see infra/SUPABASE.md) ---
# Supabase pooler (copy host from Dashboard, or run apps/api/scripts/find_pooler.py)
DATABASE_URL=postgresql+psycopg://postgres.sevwzahlsunwqbiowbcx:[password]@aws-1-ap-northeast-1.pooler.supabase.com:5432/postgres?sslmode=require
SUPABASE_DB_PASSWORD=
REDIS_URL=redis://redis:6379/0
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
SECRET_KEY=dev-only
LOG_LEVEL=info
MAX_UPLOAD_MB=15
CONFIDENCE_THRESHOLD=0.7
STORAGE_PATH=/data/uploads
SHARE_BASE_URL=http://localhost:3000/share

# --- Supabase (auth + hosted Postgres) ---
# Create project at supabase.com; enable Phone auth + SMS (Twilio/MessageBird).
# Local dev without SMS: SUPABASE_ENABLED=false (legacy anonymous path).
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_JWT_SECRET=
SUPABASE_ENABLED=false

# --- AI providers (abstraction). Live path = cloud (Gemini); falls back to mock
#     on any failure. DEMO_MODE is the separate zero-dependency safety path. ---
EXTRACTION_PROVIDER=cloud         # mock|qwen|cloud
QWEN_ENDPOINT=http://models:8001/v1
REASONING_PROVIDER=cloud          # mock|medgemma|gemini|cloud
MEDGEMMA_ENDPOINT=http://models:8002/v1

# --- Cloud (Gemini 3.5 Flash: extraction + reasoning in one provider) ---
CLOUD_API_PROVIDER=gemini         # gemini|openai
GOOGLE_API_KEY=                   # https://aistudio.google.com/apikey
OPENAI_API_KEY=                   # fallback only

# --- Telegram bot ---
TELEGRAM_BOT_TOKEN=                   # from @BotFather
TELEGRAM_SECRET=                      # random string; must match setWebhook secret_token
BRIEF_BASE_URL=http://localhost:3000  # public web URL for brief links (use tunnel URL on phone)
PUBLIC_URL=                           # public API URL for webhook (e.g. cloudflared -> :8000)

# Register webhook after tunnels are up:
#   docker compose -f infra/docker-compose.yml exec api sh -c "PYTHONPATH=/app python scripts/register_telegram_webhook.py"
# Or run scripts/telegram-tunnel.ps1 for dev tunnels.

# --- Demo ---
DEMO_MODE=false
SEED_PATIENT_ID=pat_demo

# --- Web (Claude Design) ---
# Use /api/v1 in dev (Next.js proxies to API). Production: full public API URL.
NEXT_PUBLIC_API_BASE_URL=/api/v1
NEXT_PUBLIC_DEMO_MODE=false
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_ENABLED=false
